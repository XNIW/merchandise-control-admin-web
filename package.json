{
  "name": "merchandise-control-admin-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run security:scan && npm run build",
    "security:scan": "node scripts/security-checks.mjs",
    "supabase:bootstrap-platform-admin": "node scripts/supabase/bootstrap-platform-admin.mjs",
    "test:foundation": "node --test tests/foundation/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:ui-smoke": "playwright test tests/e2e/platform-admin.spec.ts",
    "test:ui-live-auth": "PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001 PLAYWRIGHT_WEB_SERVER_COMMAND=\"npm run dev -- --hostname 127.0.0.1 --port 3001\" PLAYWRIGHT_REUSE_SERVER=0 playwright test tests/e2e/platform-admin-live-auth.spec.ts --project=chromium-desktop",
    "playwright:install": "playwright install chromium",
    "verify:full": "npm run verify && npm run test:ui-smoke"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
